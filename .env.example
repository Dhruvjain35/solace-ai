# Copy this file to `.env` and fill in real values.
# Never commit `.env`. Load via backend/lib/config.py.

# -- AI provider keys --
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# -- Runtime mode --
# "local" = in-memory storage + local disk media (no AWS needed)
# "aws"   = DynamoDB + S3 + Secrets Manager (production)
SOLACE_MODE=local

# -- AWS (only used when SOLACE_MODE=aws) --
AWS_REGION=us-east-1
DYNAMODB_TABLE_PATIENTS=solace-patients
DYNAMODB_TABLE_HOSPITALS=solace-hospitals
S3_BUCKET_MEDIA=solace-media-REPLACE-ME

# -- Local dev --
LOCAL_MEDIA_DIR=./tmp/media
LOCAL_MEDIA_BASE_URL=http://localhost:8000/media

# -- Hospitals seed (local mode only; hospitals table is seeded with this) --
DEMO_HOSPITAL_ID=demo
DEMO_HOSPITAL_NAME=Demo Medical Center
DEMO_CLINICIAN_PIN=123456
